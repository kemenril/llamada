#Handle changing around and viewing config variables
def setVar(v=""):
    if not v:   # In this case, print the whole namespace
        print(f"Session: {llamada_session}",file=sys.stderr)
        for k in conf[llamada_session].keys():
            print(f"{k:>16}: {conf[llamada_session][k]:<32}", file=sys.stderr,end="")
            if conf.has_option('DEFAULT',k):
                if conf[llamada_session][k] != conf['DEFAULT'][k]:
                    print(f"; DEFAULT: {conf['DEFAULT'][k]}",file=sys.stderr,end="")
            else:
                #We've set this variable and it doesn't exist in DEFAULT
                print("; DEFAULT: <UNSET>",file=sys.stderr,end="")
            print(file=sys.stderr)
    else:
        if not re.search(r"=",v):   #Print a single value.
            print(f"{v}: {conf.get(llamada_session,v,fallback='<Does not exist.>')}",file=sys.stdout)
            return
        else:   #Assignment
            segments = v.split('=')
            name=segments[0].lower()
            val="=".join(segments[1:])
            if not val:
                conf.remove_option(llamada_session,name)
                print(f"Remove {name}",file=sys.stderr)
            else:
                conf.set(llamada_session,name,val)
                print(f"Set {name} to {val}",file=sys.stderr)
            if name in varHooks:
                #print(f"Hook function found for {name}.  Running it.",file=sys.stderr)
                varHooks[name]()
