#Read and properly handle configuration data
def getConfig():
    conf = configparser.ConfigParser()
    #Assume llamada_state_dir,llamada_session_dir, are already set.
    conf.read([os.path.join(llamada_state_dir,"config"),os.path.join(llamada_session_dir,"config")])

    #We'll still have no section for our session if no configuration file was
    # loaded that contains it, so in that case, create an empty one.  Defaults
    # will be loaded in for most values, but maybe be explicit anyway.
    if llamada_session != 'DEFAULT' and not conf.has_section(llamada_session):
        conf.add_section(llamada_session)

    #Merge in the command-line
    if args.url:
        conf[llamada_session]["URL"] = str(args.url)
    if args.key:
        conf[llamada_session]["Key"] = str(args.key)
    if args.progress:
        conf[llamada_session]["Streaming"] = str(args.progress)
    if args.verbose:
        conf[llamada_session]["Verbose"] = str(args.verbose)

    #Load all the tools before we might write out the config
    if conf.has_option(llamada_session,"tools"):
        for t in json.loads(conf.get(llamada_session,"tools")):
            loadTool(t)
        conf.remove_option(llamada_session,"tools")
        conf.remove_option("DEFAULT","tools")

    if args.wrconfig:
        wrConfig(conf)
    return conf

