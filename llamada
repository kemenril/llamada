#This saves some history data to a file in the sandbox directory.  Maybe later look at getting it to be intelligent about not writing outside of it, but for now, it should be safe because it will always be run by the user.
def writeHistory(item):
    if not item:
        print("You must give a <history sequence number or range>=<filename> argument.",file=sys.stderr)
        return
    parts = item.split('=')
    if not len(parts) > 1:
        print("You must give a <history sequence number or range>=<filename> argument.",file=sys.stderr)
        return
    hseq = parts[0]
    path = "=".join(parts[1:])
    try:
        c = llamada_histdb_conn.cursor()
        with open(os.path.join(llamada_session_sandbox,path), "w", encoding="utf-8") as f:
            if hseq.isnumeric():    # One value
                c.execute("SELECT content FROM conversation WHERE seq = ?",(hseq,))
            else:
                hRange=hseq.split("-")
                if not hRange[0].isnumeric() or not hRange[1].isnumeric() or len(hRange) != 2:
                        print(f"Got bad history range for write: {hRange}",file=sys.stderr)
                        return
                else:   #We have a range of two reasonable numbers here.
                    c.execute("SELECT content FROM conversation WHERE seq BETWEEN ? AND ?",hRange)
            print(f"Write {hseq} to {path}", file=sys.stderr)
            for line in c.fetchall():
                f.write(line['content'])
    except Exception as e:
        print(f"Problem writing to file: {item}, {e}",file=sys.stderr)
