#Run a WASI tool
def wasmRun(tool_name: str, args_json: str, session_dir: str) -> dict:
    wasm_path = os.path.join(llamada_tool_dir,tool_name +".wasm")
    if not wasm_path:
        return {"error": f"Unknown tool: {tool_name}"}

    try:
        proc = subprocess.run(
                ["wasmedge", f"--dir=/:{session_dir}", wasm_path],
            input=args_json,
            capture_output=True,
            text=True,
            timeout=15  # Hard execution budget
        )
        if proc.returncode != 0:
            return {"error": f"Tool failed (rc={proc.returncode}): {proc.stderr.strip()}"}
        try:
            return json.loads(proc.stdout)
        except json.JSONDecodeError as e:
            return {"error": f"Invalid JSON output from tool: '{proc.stdout.strip()}' (Error: {e})"}
    except subprocess.TimeoutExpired:
        return {"error": "Tool execution timed out (15s limit)"}
    except Exception as e:
        return {"error": f"Execution error: {str(e)}"}

# Load a Python tool from disk
def loadPyTool(tool_name: str) -> bool:
    """Load a Python tool from ~/llamada/tools/<tool_name>.py"""
    tool_path = os.path.join(llamada_tool_dir, f"{tool_name}.py")
    if not os.path.isfile(tool_path):
        return False
    
    try:
        spec = importlib.util.spec_from_file_location(tool_name, tool_path)
        if spec is None or spec.loader is None:
            return False
        module = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(module)
        
        # Validate required interfaces
        if not hasattr(module, 'tool_func') or not hasattr(module, 'tool_schema'):
            print(f"Python tool {tool_name} does not seem to contain tool functions.", file=sys.stderr)
            return False
        
        # Store in pyTOOLS registry
        pyToolRegister(tool_name,module.tool_func, module.tool_schema(), False)
        return True
    except Exception as e:
        print(f"Failed to load Python tool {tool_name}: {e}", file=sys.stderr)
        return False

# Run a Python tool
def pyToolRun(name: str, args: str, sandbox: str) -> dict:
    try:
        result = pyTOOLS[name]["function"](args,{'session': llamada_session, 'sandbox_dir': sandbox, 'state_dir': llamada_state_dir, 'session_dir': llamada_session_dir, 'conf': conf})
        return json.loads(result) if isinstance(result, str) else result
    except json.JSONDecodeError as e:
        return {"error": f"Invalid JSON output from tool: {e}"}
    except Exception as e:
        return {"error": f"Python tool error: {str(e)}"}

# Validate the inbound JSON to a tool call
def validateArgs(name: str, argsStr: str):
    try:
        parsed = json.loads(argsStr)
    except json.JSONDecodeError as e:
        return {"error": f"Invalid JSON in tool arguments: {e}"}

    schema = TOOLS[name]["function"].get("parameters")
    if not schema:
        return None   #I guess we can't validate not schema.

    #This explicitly sets the value which prevents extra properties from
    #  being passed in, unless already in the schema.  If a tool 
    #  wants to allow extra properties which aren't explicitly recorded,
    #  then it will need to set this to True.
    if "additionalProperties" not in schema:
        schema = {**schema, "additionalProperties": False}

    try:
        jsonschema.validate(parsed, schema)
    except jsonschema.ValidationError as e:
        where = "/".join(str(p) for p in e.path) or "<root>"
        return {"error": f"Tool argument validation failed at {where}: {e.message}"}
    except jsonschema.SchemaError as e:
        #The schema itself is malformed.  This is our fault; try to handle it.
        print(f"Warning: schema for {name} is invalid: {e.message}", file=sys.stderr)
        return None

    return None


# Run an internal tool, if available, or a loaded Python too, or a WASI tool
def toolRun(name: str, args: str, sandbox: str) -> dict:
    if name not in TOOLS:   #Be absolutely sure we ought to run it.
        # We've been returning status information to the LLM, but we should
        # also tell the user separately.
        print(f"  \x1b[36m\u23ce\x1b[0m {name} not loaded/enabled.", file=sys.stderr,flush=True)
        return {"error": f"Tool {name} not loaded."}

    argErr = validateArgs(name, args)
    if argErr is not None:
        print(f"  \x1b[36m\u23ce\x1b[0m Tool: {name:<18}  (rejected: Validation of arguments against schema failed.)", file=sys.stderr, flush=True)
        return argErr

    print(f"  \x1b[36m\u23ce\x1b[0m Tool: {name:<18}  ", file=sys.stderr, end="")
    
    # Check in order: internal, Python, WASI
    if name in pyTOOLS:
        print("(Python: ",end='',file=sys.stderr)
        print("Built-In" if pyTOOLS[name]['builtin'] else "External",file=sys.stderr,end="")
        print(")",file=sys.stderr,flush=True)
        return pyToolRun(name, args, sandbox)
    
    print("(WASI)",file=sys.stderr,flush=True)
    return wasmRun(name, args, sandbox)

