#For tool type information in the tool list:
class ToolCategory(IntEnum):
    PYTHON_INT = 0
    PYTHON_EXT = 1
    WASI       = 2

    #This defines the expansions
    def label(self):
        return {
            ToolCategory.PYTHON_INT: "Python: Built-In",
            ToolCategory.PYTHON_EXT: "Python: External",
            ToolCategory.WASI:       "WASI",
        }[self]


#Fetch all possible tools, from anywhere, into a single dict:
def getAllTools():
    entries = {}
    for name, info in pyTOOLS.items():
        entries[name] = {
            "category": ToolCategory.PYTHON_INT if info["builtin"] else ToolCategory.PYTHON_EXT,
            "active": name in TOOLS,
            "desc": info["schema"]["function"]["description"],
        }

    # This gets us the list of WASI tools but also maybe some more external 
    #  Python.
    if os.path.exists(llamada_tool_dir):
        for fname in os.listdir(llamada_tool_dir):
            base, ext = os.path.splitext(fname)
            if base in entries:
                continue
            if ext == ".schema" and os.path.isfile(os.path.join(llamada_tool_dir, base + ".wasm")):
                active = base in TOOLS
                entries[base] = {
                    "category": ToolCategory.WASI,
                    "active": active,
                    "desc": TOOLS[base]["function"]["description"] if active else "Description not available until loaded.",
                }
            elif ext == ".py":  #If this were active, we'd have skipped it.
                entries[base] = {
                    "category": ToolCategory.PYTHON_EXT,
                    "active": False,
                    "desc": "Description not available until loaded.",
                }

    return entries

