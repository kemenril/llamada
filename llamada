#Load/unload tools
def loadTool(t):
    #Check if already in Python tools (loaded but not activated)
    if t in pyTOOLS:
        print(f"Activating Python tool {t}")
        TOOLS[t] = pyTOOLS[t]["schema"]
        return
    
    #Try loading Python tool from disk
    if loadPyTool(t):
        print(f"Loaded Python tool: {t}, activating.")
        TOOLS[t] = pyTOOLS[t]["schema"]
        return
    
    #Fallback to WASI tool
    w = os.path.join(llamada_tool_dir,f"{t}.wasm")
    s = os.path.join(llamada_tool_dir,f"{t}.schema")
    if not (os.path.isfile(w) and os.path.isfile(s)):
        print(f"Tool or schema missing for {t}.",file=sys.stderr)
        return
    #In case of a mid-session update, clear old data first.
    if t in TOOLS:
        del TOOLS[t]
    try:
        with open(s, "r", encoding="utf-8") as sFile:
            sData = sFile.read()
            TOOLS[t] =  json.loads(sData)
            if TOOLS[t]:
                print(f"Loaded {t}",file=sys.stderr)
            else:
                print(f"Failed to load {t}, but no exception thrown.",file=sys.stderr)
            sys.stderr.flush()
    except Exception as e:
        print(f"Problem loading {t}: {e}",file=sys.stderr)
        return

