#Run a WASI tool
def wasmRun(tool_name: str, args_json: str, session_dir: str) -> dict:
    wasm_path = os.path.join(llamada_tool_dir,tool_name +".wasm")
    if not wasm_path:
        return {"error": f"Unknown tool: {tool_name}"}

    try:
        proc = subprocess.run(
                ["wasmedge", f"--dir=/:{session_dir}", wasm_path],
            input=args_json,
            capture_output=True,
            text=True,
            timeout=15  # Hard execution budget
        )
        if proc.returncode != 0:
            return {"error": f"Tool failed (rc={proc.returncode}): {proc.stderr.strip()}"}
        try:
            return json.loads(proc.stdout)
        except json.JSONDecodeError as e:
            return {"error": f"Invalid JSON output from tool: '{proc.stdout.strip()}' (Error: {e})"}
    except subprocess.TimeoutExpired:
        return {"error": "Tool execution timed out (15s limit)"}
    except Exception as e:
        return {"error": f"Execution error: {str(e)}"}

# Run a built-in tool
def intToolRun(name: str, args: str, sandbox: str) -> dict:
    try:
        return json.loads(intTOOLS[name]["function"](args,sandbox))
    except json.JSONDecodeError as e:
        return {"error": f"Invalid JSON output from tool: (Error: {e})"}
    except Exception as e:
        return {"error": f"Internal tool error: {str(e)}"}
    return {"error": f"Internal tool not found: {name}"} 

# Run an internal tool, if available, or a WASI tool
def toolRun(name: str, args: str, sandbox: str) -> dict:
    if not name in TOOLS:   #Be absolutely sure we ought to run it.
        return {"error": f"Tool {name} not loaded."}
    if name in intTOOLS:
        return intToolRun(name,args,sandbox)
    return wasmRun(name,args,sandbox)

