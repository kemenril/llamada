#Check that we're asking it to do something
if not args.question:
    print("No question given, forcing interactive mode.",file=sys.stderr)
    args.interactive = True


#For rate limiting.
lastReq = 0

Q="".join(args.question)

# Main execution loop
while True:
    #We're doing odd things with control codes, and maybe we should stabilize
    #  the output streams a bit.  Flush them each time through.
    sys.stderr.flush()
    sys.stdout.flush()
    if not Q and args.interactive:
        try:
            promptString = [('bold underline',conf.get(llamada_session,'Model',fallback=fallback_model))]
            if tokenCount:
                promptString.append(('fg:ansicyan',f" ({tokenCount})"))
            promptString.append(('bold',"> "))
            Q = prompt(FormattedText(promptString),
                       key_bindings=kb, multiline=True, history=ptHist, 
                       prompt_continuation="", default=ptFill)
            ptFill = "" 
        except EOFError:
            print("Got EOF. Exiting.")
            sys.exit(0)
        except KeyboardInterrupt:
            print("Interrupt.", file=sys.stderr)
            Q = ""
            ptFill = ""
            continue

    # Local Commands
    if Q:
        components = Q.split()
        if components and components[0].lower().strip() in cmdTable:
            nCmd = components[0].lower().strip()
            nPars = " ".join(components[1:])
            
            callForm = len(signature(cmdTable[nCmd]).parameters)
            if callForm == 0:
                cmdTable[nCmd]()
            elif callForm == 1:
                cmdTable[nCmd](nPars)
            else:
                print(f"Not plumbed for commands requiring {callForm} parameters.", file=sys.stderr,flush=True)
            
            Q = ""
            continue # Skip LLM logic entirely

    # LLM
    if Q:
        messages = getHistory()

        #If it's a new session, or if we've erased the history back to the 
        # beginning of time, we'll start with an empty history, and in that
        # case, add the preamble.
        if not messages:
            if conf.has_option(llamada_session,'Prompt.preamble'):
                addHistory("system",conf.get(llamada_session,'Prompt.preamble'))
                messages = getHistory()

        addHistory("user", Q)
        messages.append({"role": "user", "content": Q})
        
        useStreaming = conf.getboolean(llamada_session, 'Streaming', fallback=False)

        #Print an indication that we are sending a query
        print("\u2199", flush=True)
        while True:  # Tool/Response internal loop

            #We use variables to adjust tool parameters, but sometimes
            # those variables are not defined, so we use None, but the
            # OpenAI library is stupid about this, or the remote systems
            # are stupid about it, and things sometimes break from that,
            # so we also filter out the Nones later.
            compParams = {
                "model": conf.get(llamada_session, 'Model', fallback=fallback_model),
                "temperature": conf.get(llamada_session, 'Model.temperature', fallback=None),
                "max_tokens": conf.get(llamada_session, 'Model.max_tokens', fallback=None),
                "top_p": conf.get(llamada_session, 'Model.top_p', fallback=None),
                "frequency_penalty": conf.get(llamada_session, 'Model.frequency_penalty', fallback=None),
                "presence_penalty": conf.get(llamada_session, 'Model.presence_penalty', fallback=None),
                "messages": messages,
                "tools": [ t for t in TOOLS.values()] if TOOLS.values() else None,
                "stream": useStreaming,
                "stream_options": {"include_usage": True} if useStreaming else None,
            }
           
            #There are probably twelve better ways to do this.
            for empty in [k for k in compParams if not compParams[k]]:
                del compParams[empty]

            #To the user, the stream starts here.  This may change when
            # the status is displayed, where very slow response is concerned.
            streamStart = time.time()

            try:
                rps = conf.getfloat(llamada_session,'RPS',fallback=None)
                if rps:
                   #When can lastReq be, and have us run now?
                   latest = time.time() - (1/rps)
                   if lastReq > latest:
                       time.sleep(lastReq-latest)

                maxRetries = conf.getint(llamada_session, 'RateLimit.MaxRetries', fallback=5)
                attempt = 0
                while True:
                    try:
                        response = c.chat.completions.create(**compParams)
                        break
                    except openai.RateLimitError as e:
                        attempt += 1
                        if attempt > maxRetries:
                            raise
                        delay = rateLimitDelay(attempt, e)
                        print(f"\r  \x1b[33m\u23f3\x1b[0m Rate limited, retrying in {delay:.1f}s "
                              f"(attempt {attempt}/{maxRetries})...\x1b[K", end="", file=sys.stderr, flush=True)
                        time.sleep(delay)
                        print("\r\x1b[K", end="", file=sys.stderr, flush=True)
                lastReq = time.time()
            except Exception as e:
                print(f"\n\x1b[31m\u26a0 LLM API Error:\x1b[0m {str(e)}", file=sys.stderr)
                break

            finalMessage = None
            finishReason = None

            if useStreaming:
                fullContent = ""
                fullReasoning = ""
                fullToolCalls = {}

                # A few bits of initialization for the stream status line.
                chunkCount = 0
                lastStatusTime = 0.0
                statusOn = False

                # This block ought to catch problems that happen if the
                # endpoint dies mid-transmission or doesn't, for some other
                # reason, furnish all the chunks.  It will also try, but
                # probably fail (due to the way this is mostly handled in
                # Python, to catch keyboard interrupts during streaming.
                #  Almsot certainly better than nothing.  Could use a ton
                # of work.
                try:
                    for chunk in response:
                        chunkCount += 1
                        # Found anything yet?
                        if not fullContent:
                            now = time.time()
                            if now - lastStatusTime > 0.25:
                                lastStatusTime = now
                                statusOn = True
                                elapsed = now - streamStart
                                rate = chunkCount / elapsed if elapsed > 0 else 0
                                status = f"  \x1b[36m\u23ce\x1b[0m Waiting on remote... {chunkCount} chunks, {elapsed:.1f}s ({rate:.1f}/s)"
                                if fullReasoning:
                                    status += f", {len(fullReasoning)} reasoning chars"
                                print(f"\r{status}\x1b[K", end="", file=sys.stderr, flush=True)
                        #Apparently sometimes there are empty chunks which 
                        # function as a heartbeat signal, but also we tack 
                        # usage onto the end in a separate chunk.  This may 
                        #screw up tool calls if it's not handled in such a 
                        # way that we forget about it before handling them 
                        # below.
                        if not chunk.choices:
                            if chunk.usage:
                                tokenCount += chunk.usage.total_tokens
                            continue

                        choice = chunk.choices[0]
                        delta = choice.delta

                        if delta.content:
                            if statusOn:
                                #First actual output.  No more status line.
                                print("\r\x1b[K", end="", file=sys.stderr, flush=True)
                                statusOn = False
                            # Just in case anything was pending.
                            sys.stderr.flush()
                            sys.stdout.flush()
                            print(delta.content, end="", flush=True)
                            fullContent += delta.content

                        if hasattr(delta,"reasoning_content") and delta.reasoning_content:
                            fullReasoning += delta.reasoning_content

                        if delta.tool_calls:
                            for tc in delta.tool_calls:
                                idx = tc.index
                                if idx not in fullToolCalls:
                                    fullToolCalls[idx] = {
                                            "id": tc.id,
                                            "type": "function",
                                            "function": {
                                                "name": tc.function.name,
                                                "arguments": tc.function.arguments or "",
                                            },
                                            "extra_content": tc.extra_content if hasattr(tc,"extra_content") else None
                                            }
                                else:
                                    fullToolCalls[idx]["function"]["arguments"] += tc.function.arguments or ""
                        if choice.finish_reason:
                            finishReason = choice.finish_reason
                            #Gemini, at least adds the (total, per call) usage on
                            # all the chunks instead of submitting it separately.
                            #We grab it from the last one, here.
                            if chunk.usage:
                                tokenCount += chunk.usage.total_tokens
                    #Clear any status line still showing (a tool-calls-only
                    #response never triggers the mid-loop clear, since that
                    #only fires once fullContent becomes non-empty).
                    if statusOn:
                        print("\r\x1b[K", end="", file=sys.stderr, flush=True)

                except (Exception, KeyboardInterrupt) as e:
                    print(f"Error, or interrupt, handling stream: {e}.  You might try again.",file=sys.stderr)
                    Q = ""
                    ptFill = ""
                    break

                #We don't print this one, because that has already been done
                # just above, but we need to assemble it for the tool handler 
                # below.
                finalMessage = {
                    "role": "assistant",
                    "content": fullContent or None,
                    "tool_calls": list(fullToolCalls.values()) if fullToolCalls else None,
                    "reasoning_content": fullReasoning or None
                }
                if fullContent:  #Maybe we printed something
                    print('',flush=True)

            else: #Streaming is off
                # Because streaming is a mess, we move this data around too.
                tokenCount += response.usage.total_tokens
                finalMessage = response.choices[0].message.model_dump()
                finishReason = response.choices[0].finish_reason
                if finalMessage["content"]:
                    print(finalMessage["content"],flush=True)

            # Actual tool execution
            #if finishReason == "tool_calls" and finalMessage.tool_calls:
            #Gemini is weird about the finish reason in this vicinity.
            # Maybe we just check for any tool calls and execute them where we
            # find them.
            if finalMessage["tool_calls"]:
                print(f"\x1b[36m\u23ce\x1b[0m Executing {len(finalMessage['tool_calls'])} tool(s)...", file=sys.stderr, flush=True)
                # No reasoning content can be kept with tool call results, or
                #  certain models get really angry.
                finalMessage.pop("reasoning_content", None)
                messages.append(finalMessage)

                for tc in finalMessage["tool_calls"]:
                    result = toolRun(tc["function"]["name"], tc["function"]["arguments"], llamada_session_sandbox)
                    messages.append({
                        "role": "tool",
                        "tool_call_id": tc["id"],
                        "content": json.dumps(result)
                    })
                continue # Go back to API call with tool results

            # Is this it?
            if finalMessage and finalMessage["content"]:
                addHistory("assistant", finalMessage["content"])
                if conf.getboolean(llamada_session, 'Verbose', fallback=False) and finalMessage.get("reasoning_content"):
                    print(f"R: {finalMessage.get('reasoning_content')}", file=sys.stderr)
            elif not finalMessage or not finalMessage.get("tool_calls"):
                print(f"\x1b[33m\u26a0\x1b[0m Model returned an empty response (finish_reason={finishReason}).", file=sys.stderr)
            break 

        Q = "" # Have to unset this eventually

    if not args.interactive:
        break
