#Remove elements from history
def rmHistory(nRanges=None):

    if not nRanges:
        print("Nothing specified to remove",file=sys.stderr)
        return
    c = llamada_histdb_conn.cursor()
    rows = 0;
    #We should accept , as a separator, but it should be functionally identical
    # to space in every case which matters.
    nRanges = nRanges.replace(',', ' ')
    #This causes Python automatically clip the extra spaces.
    nRanges = " ".join(nRanges.split())
    #Normalize the numeric ranges
    nRanges = nRanges = re.sub(r"\s*-\s*", '-', nRanges)
    #Now we have a list of numbers and ranges

    R = nRanges.split()
    for elem in R:
        if re.search(r"[^\d-]",elem):
            print(f"Bad number or sequence: {elem}",file=sys.stderr)
            return
        if re.search(r"-",elem):    #Sequence
            seqParams = elem.split("-")
            if len(seqParams) != 2:
                print("Each sequence must contain exactly two numbers.",file=sys.stderr)
                return
            if not (seqParams[0].isnumeric() and seqParams[1].isnumeric()):
                print(f"Bad number in sequence {elem}",file=sys.stderr)
                return
            #Ok, this is a valid range
            c.execute("DELETE FROM conversation WHERE seq BETWEEN ? AND ?",(seqParams[0],seqParams[1]))
            rows += c.rowcount
        else:   #Single number
            if re.search(r"\D",elem):
                # ... and a bad number
                print(f"Not a number: {elem}",file=sys.stderr)
                return
            c.execute("DELETE FROM conversation WHERE seq = ?",(elem,))
            rows += c.rowcount
    llamada_histdb_conn.commit()
    print(f"{rows} rows deleted.",file=sys.stderr)
