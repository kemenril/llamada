            subject = helpText[subject]['ptr']
        else:
            print(f"{subject}\n",file=sys.stderr)
        sHelp = helpText[subject]
        if 'shortdesc' in sHelp:
            print(sHelp['shortdesc'] + "\n",file=sys.stderr)
        if "desc" in sHelp:
            print(f"\t{sHelp['desc']}\n",file=sys.stderr)
        if "syntax" in sHelp:
            print(f"Syntax:\n\t{sHelp['syntax']}\n",file=sys.stderr)
        if "examples" in sHelp:
            print(f"Examples:\n{sHelp['examples']}\n",file=sys.stderr)
        if "also" in sHelp:
            print(f"See also:\n\t{sHelp['also']}\n",file=sys.stderr)

        #The special case of top-level help
        if not subject:
            print("The following commands are available, and will be intercepted and handled by the local software.",file=sys.stderr)
            for cmd in cmdTable.keys():
                if cmd in helpText and 'ptr' in helpText[cmd]:
                    #Maybe just skip the aliases for brevity.
                    continue
                desc = helpText[cmd]['shortdesc'] if cmd in helpText and 'shortdesc' in helpText[cmd] else "No description."
                print(f"{cmd:<16}{desc}",file=sys.stderr)
            print("You may be able to get documentation for individual commands by writing *help <command>*.",file=sys.stderr)

    else:
        print(f"No help entry found for {subject}.",file=sys.stderr)
