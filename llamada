#The standard Row factory isn't producing output that's close enough to a 
# real dictionary object to work with the OpenAI API, so a new factory.
def dbFact_dict(cursor,row):
    fields = [c[0] for c in cursor.description]
    return dict(zip(fields,row))

#Write the config back out
def wrConfig(conf):
